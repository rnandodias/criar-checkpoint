# Copie este arquivo para `.env` e preencha com as suas credenciais.
# Todos os scripts deste projeto leem as variáveis abaixo via python-dotenv.

# OpenAI (usada quando MODEL começa com `gpt-*` ou `o*-*`)
OPENAI_CREDENTIALS="sua_api_key_openai"

# Anthropic (usada quando MODEL começa com `claude-*`). Opcional — só preencha
# se for usar modelos Claude. Veja constantes MODEL nos scripts de etapa 2/3/4.
ANTHROPIC_API_KEY="sua_api_key_anthropic"

# Alura (usadas apenas pelo scraping de transcrições)
EMAIL="seu_email_alura"
PASSWORD="sua_senha_alura"
